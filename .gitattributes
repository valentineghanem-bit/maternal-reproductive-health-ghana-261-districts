# Git LFS tracking for large binary files (TECH-004 prevention — prevents binary bloat)
# Install Git LFS: https://git-lfs.github.com/

# Figures and maps
*.png filter=lfs diff=lfs merge=lfs -text
*.svg filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text

# GeoJSON source files (can be large)
*.geojson filter=lfs diff=lfs merge=lfs -text

# Large CSVs (master dataset if >50 MB)
master_*.csv filter=lfs diff=lfs merge=lfs -text

# SHAP and model output plots
outputs/figures/** filter=lfs diff=lfs merge=lfs -text
figures/** filter=lfs diff=lfs merge=lfs -text

# Poster export
poster/*.png filter=lfs diff=lfs merge=lfs -text
poster/*.pdf filter=lfs diff=lfs merge=lfs -text

# Dashboard HTML (if large)
dashboard/*.html filter=lfs diff=lfs merge=lfs -text

# Line endings — normalise across OS
*.py  text eol=lf
*.R   text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.cff text eol=lf
